---
import Target from '@/components/icons/ui/Target.astro'
import Eye from '@/components/icons/ui/Eye.astro'
import { mision, vision, objetivos } from '@/data/objetivos'
---

<section id="mision-vision" class="scroll-mt-20 bg-surface py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Misión y Visión -->
    <div class="mb-20 grid gap-8 md:grid-cols-2">
      <!-- Misión -->
      <div
        class="group relative overflow-hidden rounded-xl border border-gray-200/60 bg-white p-8 transition-all duration-500 hover:shadow-lg md:p-10"
      >
        <!-- Barra dorada superior -->
        <div
          class="bg-accent absolute top-0 left-0 h-0.5 w-full origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"
        >
        </div>

        <div class="relative">
          <div class="mb-6 flex items-center gap-4">
            <div
              class="bg-primary flex h-14 w-14 items-center justify-center rounded-xl"
            >
              <Target class="h-7 w-7 text-white" />
            </div>
            <h3 class="font-display text-2xl font-normal text-primary">
              Misión
            </h3>
          </div>
          <p class="text-text-secondary leading-relaxed">
            {mision}
          </p>
        </div>
      </div>

      <!-- Visión -->
      <div
        class="group relative overflow-hidden rounded-xl border border-gray-200/60 bg-white p-8 transition-all duration-500 hover:shadow-lg md:p-10"
      >
        <!-- Barra dorada superior -->
        <div
          class="bg-accent absolute top-0 left-0 h-0.5 w-full origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"
        >
        </div>

        <div class="relative">
          <div class="mb-6 flex items-center gap-4">
            <div
              class="bg-primary/10 flex h-14 w-14 items-center justify-center rounded-xl"
            >
              <Eye class="h-7 w-7 text-primary" />
            </div>
            <h3 class="font-display text-2xl font-normal text-primary">
              Visión
            </h3>
          </div>
          <p class="text-text-secondary leading-relaxed">
            {vision}
          </p>
        </div>
      </div>
    </div>

    <!-- Objetivos -->
    <div>
      <div class="mb-10 text-center">
        <h3
          class="text-primary mb-3 font-display text-3xl font-normal md:text-4xl"
        >
          Objetivos
        </h3>
        <div class="bg-accent mx-auto h-0.5 w-12 rounded-full"></div>
      </div>

      <div class="grid auto-rows-auto grid-cols-1 gap-5 md:grid-cols-4">
        {
          objetivos.map((objetivo) => (
            <div
              class:list={[
                'group relative flex flex-col justify-center overflow-hidden rounded-xl border border-gray-200/60 bg-white p-8 transition-all duration-500 hover:shadow-lg',
                objetivo.gridClasses,
              ]}
            >
              <div class="bg-accent absolute top-0 left-0 h-0.5 w-full origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100" />
              <p class="text-center text-sm leading-relaxed text-text-secondary md:text-base">
                {objetivo.texto}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
