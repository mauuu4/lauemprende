---
import Target from '@/components/icons/ui/Target.astro'
import Eye from '@/components/icons/ui/Eye.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import { mision, vision, objetivos } from '@/data/objetivos'
---

<section id="mision-vision" class="scroll-mt-20 bg-gray-50 py-12 md:py-16">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeader title="Misión, Visión y Objetivos" />

    <!-- Misión y Visión -->
    <div class="mb-16 grid gap-8 md:grid-cols-2">
      <!-- Misión -->
      <div
        class="group relative overflow-hidden rounded-2xl bg-white p-8 shadow-lg transition-all duration-300 hover:shadow-2xl"
      >
        <div
          class="bg-primary/5 absolute top-0 right-0 h-40 w-40 translate-x-10 -translate-y-10 rounded-full transition-transform duration-300 group-hover:scale-150"
        >
        </div>
        <div class="relative">
          <div class="mb-6 flex items-center gap-4">
            <div
              class="from-primary flex h-16 w-16 items-center justify-center rounded-xl bg-linear-to-br to-blue-800 shadow-lg"
            >
              <Target class="h-8 w-8 text-white" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900">Misión</h3>
          </div>
          <p class="leading-relaxed text-gray-700">
            {mision}
          </p>
        </div>
      </div>

      <!-- Visión -->
      <div
        class="group relative overflow-hidden rounded-2xl bg-white p-8 shadow-lg transition-all duration-300 hover:shadow-2xl"
      >
        <div
          class="bg-accent/10 absolute top-0 right-0 h-40 w-40 translate-x-10 -translate-y-10 rounded-full transition-transform duration-300 group-hover:scale-150"
        >
        </div>
        <div class="relative">
          <div class="mb-6 flex items-center gap-4">
            <div
              class="from-accent flex h-16 w-16 items-center justify-center rounded-xl bg-linear-to-br to-yellow-500 shadow-lg"
            >
              <Eye class="h-8 w-8 text-white" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900">Visión</h3>
          </div>
          <p class="leading-relaxed text-gray-700">
            {vision}
          </p>
        </div>
      </div>
    </div>

    <!-- Objetivos -->
    <div>
      <h3 class="text-primary mb-8 text-center text-3xl font-bold">
        Objetivos
      </h3>

      <div class="grid auto-rows-auto grid-cols-1 gap-6 md:grid-cols-4">
        {
          objetivos.map((objetivo) => (
            <div
              class:list={[
                'hover:border-primary/40 flex flex-col justify-center rounded-2xl border border-gray-200 bg-white p-10 shadow-lg transition-all duration-300 hover:shadow-xl',
                objetivo.gridClasses,
              ]}
            >
              <p class="text-center text-base leading-relaxed text-gray-700">
                {objetivo.texto}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
