---
import { Image } from 'astro:assets'
import { site } from '@/data/institucion'
import ButtonLink from '@/components/ui/ButtonLink.astro'
import fondo from '@/assets/images/institucional/fondo-hero.png'
import Edit from '@icons/modules/Edit.astro'
import Teacher from '@icons/modules/Teacher.astro'
import Student from '@icons/modules/Student.astro'
import Briefcase from '@icons/modules/Briefcase.astro'
import Chart from '@icons/modules/Chart.astro'
import ChevronDown from '@icons/ui/ChevronDown.astro'
import ChevronRight from '@icons/ui/ChevronRight.astro'
import { modulos } from '@/data/modulos'

const iconMap = { Edit, Teacher, Student, Briefcase, Chart }

const modulosResolved = modulos.map((m) => ({
  ...m,
  Icon: iconMap[m.icon],
}))
---

<section
  aria-labelledby="hero-title"
  class="relative overflow-hidden pt-12 pb-24 md:pt-16 md:pb-28"
>
  <Image
    src={fondo}
    alt="Fondo Hero"
    loading="eager"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <!-- Overlay institucional -->
  <div
    class="from-primary/60 via-primary/30 bg-primary/70 absolute inset-0 bg-linear-to-t to-transparent mix-blend-multiply"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">

      <h1
        id="hero-title"
        class="animate-fade-up mb-4 font-display text-4xl leading-tight font-normal text-white md:text-5xl lg:text-6xl"
        style="animation-delay: 0.1s"
      >
        Bienvenidos a <span class="text-accent">{site.name}</span>
      </h1>

      <p
        class="animate-fade-up mx-auto mb-8 max-w-3xl text-base leading-relaxed font-light text-white/75"
        style="animation-delay: 0.2s"
      >
        {site.tagline}
      </p>

      <div
        class="animate-fade-up flex flex-wrap justify-center gap-4"
        style="animation-delay: 0.3s"
      >
        <ButtonLink
          variant="primary"
          size="md"
          href="#cursos"
          target="_self"
          uppercase={false}
        >
          Ver Cursos
        </ButtonLink>
        <ButtonLink
          variant="link"
          size="md"
          href="#invitaciones"
          target="_self"
          uppercase={false}
        >
          Invitaciones
        </ButtonLink>
        <ButtonLink
          variant="secondary"
          size="md"
          href="/anuncios"
          target="_self"
          uppercase={false}
        >
          Anuncios
        </ButtonLink>
      </div>
    </div>
  </div>

</section>

<!-- Módulos de acceso rápido -->
<section class="relative -mt-16 z-20">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Acordeón en mobile -->
    <details class="group md:hidden">
      <summary
        class="text-primary flex cursor-pointer list-none items-center justify-between rounded-xl border border-gray-200/80 bg-white px-6 py-3 font-display text-lg font-normal shadow-lg transition-colors hover:bg-gray-50"
      >
        <span>Accesos Rápidos</span>
        <ChevronDown
          class="h-5 w-5 text-text-muted transition-transform duration-300 group-open:rotate-180"
        />
      </summary>

      <div
        class="mt-2 divide-y divide-gray-100 overflow-hidden rounded-xl border border-gray-200/80 bg-white shadow-lg"
      >
        {
          modulosResolved.map(({ title, subtitle, href, Icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary flex items-center gap-4 px-6 py-3.5 transition-colors hover:bg-surface"
              aria-label={`${title} — ${subtitle}`}
            >
              <div class="bg-primary/5 flex h-11 w-11 shrink-0 items-center justify-center rounded-lg">
                <Icon size={22} />
              </div>
              <div class="flex-1">
                <h3 class="text-sm font-semibold" aria-label={title}>
                  {title}
                </h3>
                <p class="text-xs text-text-muted">{subtitle}</p>
              </div>
              <ChevronRight class="h-4 w-4 shrink-0 text-text-muted" />
            </a>
          ))
        }
      </div>
    </details>

    <!-- Grid en desktop -->
    <div class="hidden gap-4 md:grid md:grid-cols-5">
      {
        modulosResolved.map(({ title, subtitle, href, Icon }, index) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="group hover:border-primary relative flex flex-col items-center overflow-hidden rounded-xl border border-gray-100 bg-white p-6 text-center shadow-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl"
            style={`animation: fadeUp 0.6s var(--ease-out-expo) ${0.1 + index * 0.08}s both`}
          >
            <div class="bg-primary/5 absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />

            <div class="group-hover:bg-primary bg-primary/5 relative z-10 mb-4 flex h-14 w-14 items-center justify-center rounded-2xl shadow-sm transition-all duration-300 group-hover:text-white">
              <Icon size={28} />
            </div>

            <h3 class="text-primary relative z-10 mb-1 text-sm font-bold transition-colors">
              {title}
            </h3>
            <span class="relative z-10 text-xs text-gray-500">{subtitle}</span>

            <div class="bg-primary absolute bottom-0 left-0 h-1 w-full scale-x-0 transition-transform duration-300 group-hover:scale-x-100" />
          </a>
        ))
      }
    </div>
  </div>
</section>
