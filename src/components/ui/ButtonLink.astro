---
interface Props {
  variant?: 'primary' | 'secondary' | 'link'
  size?: 'sm' | 'md' | 'lg'
  uppercase?: boolean
  href: string
  target?: '_blank' | '_self'
  class?: string
}

const {
  variant = 'primary',
  size = 'sm',
  uppercase = true,
  href,
  target = '_blank',
  class: className = '',
} = Astro.props

const baseClasses =
  'inline-flex items-center gap-1.5 font-semibold transition-all duration-300'

const variantClasses = {
  primary:
    'bg-accent text-primary hover:bg-accent-light rounded-lg shadow-md hover:shadow-lg',
  secondary:
    'bg-white/90 text-primary hover:bg-white rounded-lg shadow-md hover:shadow-lg',
  link: 'bg-white/10 text-white hover:bg-white/20 rounded-lg border border-white/20 hover:border-white/30 backdrop-blur-sm',
}

const sizeClasses = {
  sm: 'px-3.5 py-2 text-[11px]',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-6 py-3 text-base',
}

const uppercaseClass = uppercase ? 'uppercase tracking-wide' : ''

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${uppercaseClass} ${className}`
---

<a
  href={href}
  target={target}
  rel={target === '_blank' ? 'noopener noreferrer' : undefined}
  class={classes}
>
  <slot />
</a>
