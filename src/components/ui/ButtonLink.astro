---
interface Props {
  variant?: 'primary' | 'secondary' | 'link'
  size?: 'sm' | 'md' | 'lg'
  uppercase?: boolean
  href: string
  target?: '_blank' | '_self'
  class?: string
  'aria-label'?: string
}

const {
  variant = 'primary',
  size = 'sm',
  uppercase = true,
  href,
  target = '_blank',
  class: className = '',
  'aria-label': ariaLabel,
} = Astro.props

const baseClasses =
  'inline-flex items-center gap-1.5 font-semibold transition-all duration-300 rounded-lg shadow-lg hover:scale-105'

const variantClasses = {
  primary: 'bg-primary text-white hover:bg-primary-light',
  secondary: 'bg-accent/90 text-primary hover:bg-accent',
  link: 'bg-white/90 text-gray-900 hover:bg-white',
}

const sizeClasses = {
  sm: 'px-3.5 py-2 text-[11px]',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-6 py-3 text-base',
}

// Detectar si es enlace externo para tracking
const isExternal = href.startsWith('http') && !href.includes('lauemprende.com')
---

<a
  href={href}
  target={target}
  rel={target === '_blank' ? 'noopener noreferrer' : undefined}
  class:list={[
    baseClasses,
    variantClasses[variant],
    sizeClasses[size],
    uppercase && 'uppercase tracking-wide',
    className,
  ]}
  aria-label={ariaLabel}
  data-track-click={isExternal ? true : undefined}
>
  <slot />
</a>
