---
interface Props {
  class?: string
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl'
}

const { class: className = '', size = 'md' } = Astro.props

const sizeClasses = {
  xs: 'h-10 w-auto',
  sm: 'h-12 w-auto',
  md: 'h-16 w-auto',
  lg: 'h-20 w-auto',
  xl: 'h-24 w-auto',
}
---

<img
  src="/favicon.svg"
  alt="Logo de La UEmprende EP"
  class:list={[sizeClasses[size], className]}
  loading="eager"
  decoding="async"
/>
