---
import { site } from '@/data/institucion'

interface Props {
  class?: string
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl'
  loading?: 'eager' | 'lazy'
}

const { class: className = '', size = 'md', loading = 'eager' } = Astro.props

const sizeClasses = {
  xs: 'h-10 w-auto',
  sm: 'h-12 w-auto',
  md: 'h-16 w-auto',
  lg: 'h-20 w-auto',
  xl: 'h-24 w-auto',
}
---

<img
  src="/favicon.svg"
  alt={`Logo de ${site.name}`}
  class:list={[sizeClasses[size], className]}
  loading={loading}
  decoding="async"
/>
