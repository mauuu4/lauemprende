---
import { Image } from 'astro:assets'
import { site } from '@/data/institucion'
import logoSrc from '@public/favicon.svg'

interface Props {
  class?: string
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl'
  loading?: 'eager' | 'lazy'
}

const { class: className = '', size = 'md', loading = 'eager' } = Astro.props

const sizeMap = {
  xs: { width: 40, height: 40 },
  sm: { width: 48, height: 48 },
  md: { width: 64, height: 64 },
  lg: { width: 80, height: 80 },
  xl: { width: 96, height: 96 },
}

const sizeClasses = {
  xs: 'h-10 w-auto',
  sm: 'h-12 w-auto',
  md: 'h-16 w-auto',
  lg: 'h-20 w-auto',
  xl: 'h-24 w-auto',
}
---

<Image
  src={logoSrc}
  alt={`Logo de ${site.name}`}
  width={sizeMap[size].width}
  height={sizeMap[size].height}
  class:list={[sizeClasses[size], className]}
  loading={loading}
  decoding="async"
/>
