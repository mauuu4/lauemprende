---
interface Props {
  title: string
  subtitle?: string
  class?: string
}

const { title, subtitle, class: className = '' } = Astro.props
---

<div class:list={['mb-14 text-center', className]}>
  <h2
    class="text-primary mb-3 font-display text-3xl font-normal md:text-4xl lg:text-[2.75rem]"
  >
    {title}
  </h2>
  <div class="bg-accent mx-auto h-0.5 w-12 rounded-full"></div>
  {
    subtitle && (
      <p class="mt-4 max-w-2xl mx-auto text-text-secondary text-base leading-relaxed">
        {subtitle}
      </p>
    )
  }
</div>
