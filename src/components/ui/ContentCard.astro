---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import type { Enlace } from '@/types'
import EnlaceGroup from '@/components/ui/EnlaceGroup.astro'

interface Props {
  titulo: string
  descripcion?: string
  /** Fecha en formato ISO (e.g. '2025-03-01') — usada para el atributo datetime */
  fecha: string
  /** Fecha formateada en español para mostrar al usuario */
  fechaFormateada: string
  imagen?: ImageMetadata | string
  video?: string
  enlaces?: Enlace[]
  loading?: 'eager' | 'lazy'
}

const {
  titulo,
  descripcion,
  fecha,
  fechaFormateada,
  imagen,
  video,
  enlaces = [],
  loading = 'lazy',
} = Astro.props
---

<article
  class="group relative flex flex-col overflow-hidden rounded-xl border border-gray-200/60 bg-white transition-all duration-500 hover:-translate-y-1 hover:shadow-lg"
>
  <!-- Media -->
  {
    video ? (
      video.endsWith('.mp4') ? (
        <div class="aspect-video w-full">
          <video
            src={video}
            controls
            preload="metadata"
            class="h-full w-full object-cover"
          >
            Tu navegador no soporta la reproducción de video.
          </video>
        </div>
      ) : (
        <div class="aspect-video w-full">
          <iframe
            src={video}
            title={titulo}
            class="h-full w-full"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      )
    ) : imagen ? (
      typeof imagen === 'string' ? (
        <div class="w-full overflow-hidden bg-gray-50">
          <img
            src={imagen}
            alt={titulo}
            width="600"
            height="340"
            class="h-full w-full object-contain transition-transform duration-700 group-hover:scale-105"
            loading={loading}
          />
        </div>
      ) : (
        <div class="w-full overflow-hidden bg-gray-50">
          <Image
            src={imagen}
            alt={titulo}
            width={600}
            height={imagen.height}
            class="h-full w-full object-contain transition-transform duration-700 group-hover:scale-105"
            loading={loading}
          />
        </div>
      )
    ) : (
      <div class="bg-surface flex aspect-video w-full items-center justify-center">
        <slot name="placeholder-icon" />
      </div>
    )
  }

  <!-- Cuerpo -->
  <div class="flex flex-1 flex-col p-6">
    <time
      class="mb-2 block text-[11px] font-medium tracking-wider text-text-muted uppercase"
      datetime={fecha}
    >
      {fechaFormateada}
    </time>
    <h2 class="text-primary mb-3 font-display text-lg font-normal">{titulo}</h2>
    {
      descripcion && (
        <p class="mb-4 flex-1 text-sm leading-relaxed text-text-secondary">
          {descripcion}
        </p>
      )
    }
    {enlaces.length > 0 && <EnlaceGroup enlaces={enlaces} />}
  </div>
</article>
