---
import Mail from '@/components/icons/contact/Mail.astro'
import User from '@/components/icons/ui/User.astro'

interface Props {
  nombre: string
  cargo: string
  email: string
}

const { nombre, cargo, email } = Astro.props
---

<div
  class="group relative flex flex-col items-center overflow-hidden rounded-xl border border-gray-200/60 bg-white p-6 transition-all duration-500 hover:-translate-y-1 hover:shadow-lg"
>
  <!-- Barra dorada superior -->
  <div
    class="bg-accent absolute top-0 left-0 h-0.5 w-full origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"
  >
  </div>

  <div
    class="bg-primary mb-5 flex h-24 w-24 items-center justify-center rounded-full"
  >
    <User class="h-12 w-12 text-white/80" />
  </div>

  <h3
    class="text-primary mb-1.5 text-center font-display text-base font-normal leading-snug"
  >
    {nombre}
  </h3>

  <p class="mb-5 text-center text-xs text-text-muted">
    {cargo}
  </p>

  <a
    href={`mailto:${email}`}
    class="bg-surface text-primary hover:bg-accent hover:text-primary mt-auto flex w-full items-center justify-center gap-2 rounded-lg px-4 py-2.5 text-xs font-medium transition-all duration-300"
  >
    <Mail />
    <span class="truncate">{email}</span>
  </a>
</div>
