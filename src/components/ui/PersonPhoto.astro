---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { site } from '@/data/institucion'

interface Props {
  src: ImageMetadata
  alt: string
  width: number
  height: number
  nombre: string
  cargo?: string
  organizacion?: string
  loading?: 'eager' | 'lazy'
}

const {
  src,
  alt,
  width,
  height,
  nombre,
  cargo,
  organizacion = site.fullName,
  loading = 'lazy',
} = Astro.props
---

<div class="group">
  <div class="overflow-hidden rounded-xl border border-gray-200/60 shadow-lg">
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      format="webp"
      loading={loading}
      class="aspect-3/4 w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
    />
  </div>
  <div
    class="mt-5 rounded-xl border border-gray-200/60 bg-white p-5"
  >
    <h3 class="text-primary mb-1 font-display text-xl font-normal">
      {nombre}
    </h3>
    {cargo && <p class="text-sm text-text-secondary">{cargo}</p>}
    <p class="mt-2 text-[11px] tracking-wider text-text-muted uppercase">
      {organizacion}
    </p>
  </div>
</div>
