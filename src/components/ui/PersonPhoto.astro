---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
  alt: string
  width: number
  height: number
  nombre: string
  cargo?: string
  organizacion?: string
  loading?: 'eager' | 'lazy'
}

const {
  src,
  alt,
  width,
  height,
  nombre,
  cargo,
  organizacion = 'LA UEMPRENDE EP - Empresa Pública',
  loading = 'lazy',
} = Astro.props
---

<div>
  <div class="overflow-hidden rounded-2xl shadow-xl">
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      class="aspect-3/4 w-full object-cover"
    />
  </div>
  <div class="mt-6 rounded-xl border border-gray-200 bg-white p-6 shadow-md">
    <h3 class="text-primary mb-1 text-xl font-bold">{nombre}</h3>
    {cargo && <p class="text-sm font-medium text-gray-600">{cargo}</p>}
    <p class="mt-3 text-xs text-gray-500">{organizacion}</p>
  </div>
</div>
