---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  titulo: string
  descripcion?: string
  imagen: ImageMetadata
  href?: string
}

const { titulo, descripcion, imagen, href = '/anuncios' } = Astro.props
---

<!-- Overlay -->
<div
  id="announcement-overlay"
  class="fixed inset-0 z-9998 bg-black/40 transition-opacity duration-300"
  aria-hidden="true"
>
</div>

<!-- Modal -->
<dialog
  id="announcement-modal"
  class="fixed inset-0 z-9999 m-auto flex max-h-[90dvh] w-[92vw] max-w-lg flex-col overflow-hidden rounded-2xl border border-gray-200/40 bg-white shadow-2xl outline-none transition-all duration-300 open:animate-modal-in sm:w-full"
  aria-labelledby="announcement-title"
>
  <!-- Botón cerrar -->
  <button
    id="announcement-close"
    type="button"
    class="absolute top-3 right-3 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-black/20 text-white/90 shadow-lg backdrop-blur-md transition-all duration-200 hover:bg-black/30 hover:text-white hover:shadow-xl focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:outline-none cursor-pointer"
    aria-label="Cerrar anuncio"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Contenido clickeable -->
  <a
    href={href}
    class="group flex flex-col overflow-hidden focus-visible:outline-none"
  >
    <!-- Imagen -->
    <div class="relative w-full overflow-hidden bg-surface">
      <Image
        src={imagen}
        alt={titulo}
        width={600}
        height={850}
        format="webp"
        class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-[1.02]"
        loading="eager"
      />
    </div>

    <!-- Texto -->
    <div class="flex flex-col gap-2 p-5 sm:p-6">
      <h2
        id="announcement-title"
        class="text-primary font-display text-xl leading-snug sm:text-2xl"
      >
        {titulo}
      </h2>

      {
        descripcion && (
          <p class="line-clamp-3 text-sm leading-relaxed text-text-secondary">
            {descripcion}
          </p>
        )
      }

      <span
        class="text-primary mt-1 inline-flex items-center gap-1.5 text-sm font-medium transition-colors group-hover:text-accent-dark"
      >
        Ver más anuncios
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-200 group-hover:translate-x-1"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </span>
    </div>
  </a>
</dialog>

<style>
  @keyframes modal-in {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .animate-modal-in {
    animation: modal-in 0.4s var(--ease-out-expo) both;
  }

  /* Ocultar modal y overlay cuando están cerrados */
  #announcement-overlay.hidden,
  #announcement-modal.hidden {
    display: none;
  }

  /* Quitar el backdrop nativo del dialog */
  #announcement-modal::backdrop {
    display: none;
  }
</style>

<script>
  function initAnnouncementModal() {
    const modal = document.getElementById(
      'announcement-modal',
    ) as HTMLDialogElement | null
    const overlay = document.getElementById('announcement-overlay')
    const closeBtn = document.getElementById('announcement-close')

    if (!modal || !overlay || !closeBtn) return

    // Verificar si el usuario ya cerró el modal en esta sesión
    const dismissed = sessionStorage.getItem('announcement-dismissed')
    if (dismissed) {
      modal.classList.add('hidden')
      overlay.classList.add('hidden')
      return
    }

    // Mostrar el modal
    modal.showModal()

    function closeModal() {
      if (!modal || !overlay) return
      sessionStorage.setItem('announcement-dismissed', 'true')
      modal.close()
      modal.classList.add('hidden')
      overlay.classList.add('hidden')
    }

    // Cerrar con botón X
    closeBtn.addEventListener('click', (e) => {
      e.stopPropagation()
      closeModal()
    })

    // Cerrar al hacer click en el overlay
    overlay.addEventListener('click', closeModal)

    // Cerrar con Escape (el dialog ya lo maneja, pero asegurar limpieza)
    modal.addEventListener('close', () => {
      sessionStorage.setItem('announcement-dismissed', 'true')
      modal.classList.add('hidden')
      overlay.classList.add('hidden')
    })
  }

  // Ejecutar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', initAnnouncementModal)

  // Soporte para View Transitions de Astro
  document.addEventListener('astro:page-load', initAnnouncementModal)
</script>
