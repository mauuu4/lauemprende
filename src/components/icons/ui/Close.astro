---
interface Props {
  size?: number
  class?: string
}

const { size = 24, class: className = '' } = Astro.props
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M18 6L6 18M6 6l12 12"></path>
</svg>
