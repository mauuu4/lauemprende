---
interface Props {
  size?: number
  class?: string
}

const { size = 24, class: className = '' } = Astro.props
---

<svg
  width={size}
  height={size}
  class={className}
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  aria-hidden="true"
>
  <path
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
</svg>
