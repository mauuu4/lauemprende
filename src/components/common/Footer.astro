---
import { site, infoContacto } from '@/data/institucion'
import { footerLinks } from '@/data/navLinks'
import Logo from '@/components/ui/Logo.astro'
import Facebook from '@icons/social/Facebook.astro'
import Twitter from '@icons/social/Twitter.astro'
import YouTube from '@icons/social/YouTube.astro'
import MapPin from '@icons/contact/MapPin.astro'
import Phone from '@icons/contact/Phone.astro'
import Mail from '@icons/contact/Mail.astro'

const socialLinks = [
  {
    href: infoContacto.redesSociales.facebook,
    icon: Facebook,
    label: 'Facebook',
  },
  {
    href: infoContacto.redesSociales.youtube,
    icon: YouTube,
    label: 'YouTube',
  },
  {
    href: infoContacto.redesSociales.twitter,
    icon: Twitter,
    label: 'X/Twitter',
  },
]

const contactInfo = [
  {
    href: infoContacto.mapsUrl,
    isExternal: true,
    icon: MapPin,
    label: 'Ubicación en Google Maps',
    text: infoContacto.direccion,
  },
  {
    href: infoContacto.telefonoHref,
    isExternal: false,
    icon: Phone,
    label: `Llamar al ${infoContacto.telefono}`,
    text: infoContacto.telefono,
  },
  {
    href: `mailto:${infoContacto.emailPrincipal}`,
    isExternal: false,
    icon: Mail,
    label: `Enviar correo a ${infoContacto.emailPrincipal}`,
    text: infoContacto.emailPrincipal,
  },
]

const currentYear = new Date().getFullYear()
---

<footer class="bg-primary text-white">
  <div class="mx-auto max-w-7xl px-6 py-12 md:py-14">
    <!-- Grid principal -->
    <div
      class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-12 lg:gap-8"
    >
      <!-- Marca y descripción -->
      <div
        class="flex flex-col items-center gap-4 text-center md:items-start md:text-left lg:col-span-5"
      >
        <a href="/" class="flex items-center gap-3">
          <Logo size="lg" loading="lazy" />
          <div class="flex flex-col">
            <span class="text-lg font-bold tracking-wide uppercase"
              >{site.name}</span
            >
            <span
              class="text-[10px] font-medium tracking-widest text-white/35 uppercase"
              >Empresa Pública</span
            >
          </div>
        </a>
        <p class="max-w-sm text-sm leading-relaxed text-white/45">
          Entre las líneas de servicios de la {site.fullName}, se encuentra: {
            site.tagline.charAt(0).toLowerCase() + site.tagline.slice(1)
          }
        </p>
        <div class="flex gap-2">
          {
            socialLinks.map(({ href, icon: Icon, label }) => (
              <a
                href={href}
                target="_blank"
                rel="nofollow noreferrer noopener"
                class="flex size-8 items-center justify-center rounded-md bg-white/6 text-white/50 transition-colors duration-200 hover:bg-white/10 hover:text-white"
                aria-label={label}
              >
                <Icon />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Links legales -->
      <div class="text-center md:text-left lg:col-span-3">
        <h3
          class="mb-4 text-[11px] font-semibold tracking-[0.15em] text-white/30 uppercase"
        >
          Información legal
        </h3>
        <ul class="space-y-2.5">
          {
            footerLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-white/50 transition-colors duration-200 hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contacto -->
      <div class="text-center md:text-left lg:col-span-4">
        <h3
          class="mb-4 text-[11px] font-semibold tracking-[0.15em] text-white/30 uppercase"
        >
          Contacto
        </h3>
        <ul class="space-y-3">
          {
            contactInfo.map(
              ({ href, icon: Icon, text, isExternal, label }) => (
                <li>
                  <a
                    href={href}
                    target={isExternal ? '_blank' : undefined}
                    rel={
                      isExternal ? 'nofollow noreferrer noopener' : undefined
                    }
                    class="flex items-start justify-center gap-2.5 text-sm text-white/50 transition-colors duration-200 hover:text-white md:justify-start"
                    aria-label={label}
                  >
                    <Icon class="mt-0.5 shrink-0 text-white/25" />
                    <span class="wrap-break-word">{text}</span>
                  </a>
                </li>
              )
            )
          }
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 border-t border-white/6 pt-6 text-center">
      <p class="text-xs text-white/25">
        &copy; {currentYear}
        {site.fullName}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
