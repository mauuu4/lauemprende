---
import { infoContacto } from '@/data/contacto'
import Logo from '@/components/ui/Logo.astro'
import Facebook from '@icons/social/Facebook.astro'
import Twitter from '@icons/social/Twitter.astro'
import YouTube from '@icons/social/YouTube.astro'
import MapPin from '@icons/contact/MapPin.astro'
import Phone from '@icons/contact/Phone.astro'
import Mail from '@icons/contact/Mail.astro'

const socialLinks = [
  {
    href: infoContacto.redesSociales.facebook,
    icon: Facebook,
    label: 'Facebook',
  },
  {
    href: infoContacto.redesSociales.youtube,
    icon: YouTube,
    label: 'YouTube',
  },
  {
    href: infoContacto.redesSociales.twitter,
    icon: Twitter,
    label: 'X/Twitter',
  },
]

const contactInfo = [
  {
    href: infoContacto.mapsUrl,
    isExternal: true,
    icon: MapPin,
    label: 'Ubicación en Google Maps',
    text: infoContacto.direccion,
  },
  {
    href: infoContacto.telefonoHref,
    isExternal: false,
    icon: Phone,
    label: `Llamar al ${infoContacto.telefono}`,
    text: infoContacto.telefono,
  },
  {
    href: `mailto:${infoContacto.emailPrincipal}`,
    isExternal: false,
    icon: Mail,
    label: `Enviar correo a ${infoContacto.emailPrincipal}`,
    text: infoContacto.emailPrincipal,
  },
]

const legalLinks = [
  { href: '/transparencia', label: 'Portal de Transparencia' },
  { href: '/legislacion', label: 'Legislación' },
  { href: '/rendicion-de-cuentas', label: 'Rendición de Cuentas' },
  { href: '/contactos', label: 'Contactos' },
]

const currentYear = new Date().getFullYear()
---

<footer class="bg-primary-dark border-accent border-t-2 py-8 text-white">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4 lg:gap-12">
      <div
        class="flex flex-col items-center gap-4 text-center md:col-span-2 md:text-left lg:items-start"
      >
        <a href="/" class="flex items-center gap-2 hover:opacity-90">
          <Logo size="xl" />
          <span class="text-2xl font-bold uppercase">La UEmprende</span>
        </a>
        <p class="text-secondary max-w-lg text-sm leading-relaxed">
          Entre las líneas de servicios de La EMPRESA PUBLICA LA UEMPRENDE EP,
          se encuentra: diseño, gestión, implementación, operación y
          administración de proyectos de obras, bienes y servicios, en todas sus
          formas y apoyo en proyectos promovidos por la Universidad Técnica del
          Norte.
        </p>

        <div class="flex gap-4">
          {
            socialLinks.map(({ href, icon: Icon, label }) => (
              <a
                href={href}
                target="_blank"
                rel="nofollow noreferrer noopener"
                class="bg-primary hover:bg-accent hover:text-primary flex size-9 items-center justify-center rounded-full transition-all hover:scale-110"
                aria-label={label}
              >
                <Icon />
              </a>
            ))
          }
        </div>
      </div>
      <div class="text-center md:text-left">
        <h3 class="mb-6 text-sm font-bold text-white uppercase">
          Información legal
        </h3>
        <ul class="text-secondary space-y-3 text-sm">
          {
            legalLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="hover:text-accent transition-colors hover:underline"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="text-center md:text-left">
        <h3 class="mb-6 text-sm font-bold text-white uppercase">Contacto</h3>
        <ul class="text-secondary space-y-3 text-sm">
          {
            contactInfo.map(({ href, icon: Icon, text, isExternal, label }) => (
              <li>
                <a
                  href={href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'nofollow noreferrer noopener' : undefined}
                  class="hover:text-accent flex items-start justify-center gap-3 transition-colors md:justify-start"
                  aria-label={label}
                >
                  <Icon class="shrink-0" />
                  <span class="wrap-break-word">{text}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="border-border-light text-muted mt-8 border-t pt-6 text-center text-sm"
    >
      <p>
        &copy; {currentYear} Empresa Pública LA UEMPRENDE E.P. Todos los derechos
        reservados.
      </p>
    </div>
  </div>
</footer>
