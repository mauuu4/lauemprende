---
import type { NavLink } from '@/types'
import { site } from '@/data/institucion'
import Logo from '@/components/ui/Logo.astro'
import MenuIcon from '@icons/ui/Menu.astro'
import CloseIcon from '@icons/ui/Close.astro'
import ChevronDown from '@icons/ui/ChevronDown.astro'
import { navLinks } from '@/data/navLinks'

const { pathname } = Astro.url

const isActive = (link: NavLink): boolean => {
  if (link.href) return pathname === link.href
  if (link.children)
    return link.children.some((child) => pathname === child.href)
  return false
}

const isChildActive = (href: string) => pathname === href
---

<header
  id="site-header"
  class="fixed top-0 z-50 w-full transition-all duration-300"
>
  <nav
    id="site-nav"
    class="bg-primary border-b border-white/6 transition-all duration-300"
  >
    <div
      class="mx-auto flex max-w-7xl items-center justify-between px-6 py-2.5"
    >
      <a href="/" class="group flex items-center gap-3">
        <Logo size="sm" />
        <div class="flex flex-col">
          <span
            class="text-sm leading-tight font-bold tracking-wide text-white uppercase"
          >
            {site.name}
          </span>
          <span
            class="text-[10px] leading-tight font-medium tracking-wider text-white/40 uppercase"
          >
            Empresa Pública
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden items-center gap-0.5 lg:flex">
        {
          navLinks.map((link) =>
            link.children ? (
              <div class="group relative">
                <button
                  type="button"
                  class:list={[
                    'relative flex items-center gap-1 px-3 py-2 text-[13px] font-medium tracking-wide uppercase transition-colors duration-200',
                    isActive(link)
                      ? 'text-white'
                      : 'text-white/60 hover:text-white',
                  ]}
                >
                  {link.label}
                  <ChevronDown
                    size={12}
                    class="opacity-40 transition-transform duration-200 group-hover:rotate-180"
                  />
                  {isActive(link) && (
                    <span class="bg-accent absolute bottom-0.5 left-3 right-3 h-px rounded-full" />
                  )}
                </button>
                {/* Dropdown */}
                <div class="pointer-events-none absolute top-full left-0 z-50 min-w-56 translate-y-1 pt-2 opacity-0 transition-all duration-200 ease-out group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100">
                  <div class="overflow-hidden rounded-lg bg-white py-1.5 shadow-xl ring-1 ring-black/5">
                    {link.children.map((child) => (
                      <a
                        href={child.href}
                        class:list={[
                          'group/item flex items-center gap-3 px-4 py-2 text-[13px] transition-colors duration-150',
                          isChildActive(child.href)
                            ? 'bg-surface text-primary font-semibold'
                            : 'text-text-secondary hover:bg-surface hover:text-primary',
                        ]}
                      >
                        <span
                          class:list={[
                            'h-1 w-1 rounded-full transition-all duration-200',
                            isChildActive(child.href)
                              ? 'bg-accent scale-125'
                              : 'bg-text-muted/25 group-hover/item:bg-primary group-hover/item:scale-125',
                          ]}
                        />
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'relative px-3 py-2 text-[13px] font-medium tracking-wide uppercase transition-colors duration-200',
                  isActive(link)
                    ? 'text-white'
                    : 'text-white/60 hover:text-white',
                ]}
              >
                {link.label}
                {isActive(link) && (
                  <span class="bg-accent absolute bottom-0.5 left-3 right-3 h-px rounded-full" />
                )}
              </a>
            )
          )
        }
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="menu-toggle"
        class="relative rounded-md p-2 text-white/70 transition-colors hover:bg-white/10 hover:text-white lg:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        type="button"
      >
        <span id="menu-icon">
          <MenuIcon />
        </span>
        <span id="close-icon" class="hidden">
          <CloseIcon />
        </span>
      </button>
    </div>
  </nav>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="bg-primary hidden border-t border-white/6 lg:hidden"
  >
    <div class="space-y-0.5 px-4 py-3">
      {
        navLinks.map((link) =>
          link.children ? (
            <div class="mobile-accordion">
              <button
                type="button"
                class:list={[
                  'flex w-full items-center justify-between px-4 py-2.5 text-sm font-medium tracking-wide uppercase transition-colors duration-200',
                  isActive(link)
                    ? 'text-white'
                    : 'text-white/60 hover:text-white',
                ]}
                data-accordion-toggle
              >
                {link.label}
                <ChevronDown
                  size={14}
                  class="accordion-chevron opacity-40 transition-transform duration-200"
                />
              </button>
              <div class="accordion-content hidden pb-1 pl-4">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block px-4 py-2 text-sm transition-colors duration-200',
                      isChildActive(child.href)
                        ? 'text-white font-medium'
                        : 'text-white/40 hover:text-white/70',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'block px-4 py-2.5 text-sm font-medium tracking-wide uppercase transition-colors duration-200',
                isActive(link)
                  ? 'text-white'
                  : 'text-white/60 hover:text-white',
              ]}
            >
              {link.label}
            </a>
          )
        )
      }
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const toggle = document.getElementById('menu-toggle')
    const mobileMenu = document.getElementById('mobile-menu')
    const menuIcon = document.getElementById('menu-icon')
    const closeIcon = document.getElementById('close-icon')

    if (toggle && mobileMenu && menuIcon && closeIcon) {
      toggle.addEventListener('click', () => {
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true'
        toggle.setAttribute('aria-expanded', String(!isExpanded))
        mobileMenu.classList.toggle('hidden')
        menuIcon.classList.toggle('hidden')
        closeIcon.classList.toggle('hidden')
      })
    }

    // Acordeón móvil
    const accordionToggles = document.querySelectorAll(
      '[data-accordion-toggle]'
    )
    accordionToggles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.closest('.mobile-accordion')
        const content = parent?.querySelector('.accordion-content')
        const chevron = btn.querySelector('.accordion-chevron')

        if (content && chevron) {
          content.classList.toggle('hidden')
          chevron.classList.toggle('rotate-180')
        }
      })
    })
  }

  initHeader()
</script>
