---
import Logo from '@/components/ui/Logo.astro'
import MenuIcon from '@icons/ui/Menu.astro'
import CloseIcon from '@icons/ui/Close.astro'
import ChevronDown from '@icons/ui/ChevronDown.astro'

interface NavChild {
  href: string
  label: string
}

interface NavLink {
  href?: string
  label: string
  children?: NavChild[]
}

const { pathname } = Astro.url

const isActive = (link: NavLink): boolean => {
  if (link.href) return pathname === link.href
  if (link.children)
    return link.children.some((child) => pathname === child.href)
  return false
}

const isChildActive = (href: string) => pathname === href

const navLinks: NavLink[] = [
  { href: '/', label: 'Inicio' },
  {
    label: 'Institución',
    children: [
      { href: '/quienes-somos', label: 'Quiénes somos' },
      { href: '/mision-vision-objetivos', label: 'Misión, Visión y Objetivos' },
      {
        href: '/estructura-organizacional',
        label: 'Estructura Organizacional',
      },
      { href: '/galeria', label: 'Galería' },
    ],
  },
  { href: '/servicios', label: 'Servicios' },
  {
    label: 'Transparencia',
    children: [
      { href: '/transparencia', label: 'LOTAIP' },
      { href: '/legislacion', label: 'Legislación' },
      { href: '/rendicion-de-cuentas', label: 'Rendición de Cuentas' },
    ],
  },
  { href: '/noticias', label: 'Noticias' },
  { href: '/anuncios', label: 'Anuncios' },
  { href: '/contactos', label: 'Contactos' },
]
---

<header
  class="bg-primary border-accent fixed top-0 z-50 w-full border-b-2 text-white shadow-md"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-2">
    <a href="/" class="flex items-center gap-2 font-bold uppercase">
      <Logo size="sm" />
      <span class="text-lg">La Uemprende</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden gap-4 lg:flex lg:gap-6">
      {
        navLinks.map((link) =>
          link.children ? (
            <div class="group relative">
              <button
                type="button"
                class:list={[
                  'flex items-center gap-1 text-sm font-semibold tracking-wide uppercase transition-colors duration-300',
                  isActive(link)
                    ? 'text-white'
                    : 'text-secondary hover:text-white',
                ]}
              >
                {link.label}
                <ChevronDown
                  size={16}
                  class="transition-transform duration-300 group-hover:rotate-180"
                />
              </button>
              <span
                class:list={[
                  'block h-0.5 transition-all duration-300',
                  isActive(link)
                    ? 'bg-accent max-w-full'
                    : 'max-w-0 bg-white group-hover:max-w-full',
                ]}
              />
              {/* Dropdown panel */}
              <div class="invisible absolute top-full left-0 z-50 mt-2 min-w-56 rounded-lg bg-white py-2 opacity-0 shadow-xl transition-all duration-200 group-hover:visible group-hover:opacity-100">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block px-4 py-2.5 text-sm font-medium transition-colors duration-200',
                      isChildActive(child.href)
                        ? 'bg-primary/10 text-primary font-bold'
                        : 'hover:text-primary text-gray-700 hover:bg-gray-100',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'group text-sm font-semibold tracking-wide uppercase transition-colors duration-300',
                isActive(link)
                  ? 'text-white'
                  : 'text-secondary hover:text-white',
              ]}
            >
              {link.label}
              <span
                class:list={[
                  'block h-0.5 transition-all duration-300',
                  isActive(link)
                    ? 'bg-accent max-w-full'
                    : 'max-w-0 bg-white group-hover:max-w-full',
                ]}
              />
            </a>
          )
        )
      }
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="hover:bg-primary-light rounded-md p-2 transition-colors lg:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      type="button"
    >
      <span id="menu-icon">
        <MenuIcon />
      </span>
      <span id="close-icon" class="hidden">
        <CloseIcon />
      </span>
    </button>
  </nav>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="bg-primary border-primary-light hidden border-t lg:hidden"
  >
    <div class="space-y-1 px-6 py-4">
      {
        navLinks.map((link) =>
          link.children ? (
            <div class="mobile-accordion">
              <button
                type="button"
                class:list={[
                  'flex w-full items-center justify-between rounded-md px-3 py-2.5 text-base font-semibold tracking-wide uppercase transition-colors duration-200',
                  isActive(link)
                    ? 'bg-primary-light text-white'
                    : 'hover:bg-primary-light text-secondary hover:text-white',
                ]}
                data-accordion-toggle
              >
                {link.label}
                <ChevronDown
                  size={18}
                  class="accordion-chevron transition-transform duration-300"
                />
              </button>
              <div class="accordion-content hidden pl-4">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block rounded-md px-3 py-2 text-sm font-medium transition-colors duration-200',
                      isChildActive(child.href)
                        ? 'bg-primary-light text-white'
                        : 'hover:bg-primary-light text-secondary hover:text-white',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'block rounded-md px-3 py-2.5 text-base font-semibold tracking-wide uppercase transition-colors duration-200',
                isActive(link)
                  ? 'bg-primary-light text-white'
                  : 'hover:bg-primary-light text-secondary hover:text-white',
              ]}
            >
              {link.label}
            </a>
          )
        )
      }
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const toggle = document.getElementById('menu-toggle')
    const mobileMenu = document.getElementById('mobile-menu')
    const menuIcon = document.getElementById('menu-icon')
    const closeIcon = document.getElementById('close-icon')

    if (toggle && mobileMenu && menuIcon && closeIcon) {
      toggle.addEventListener('click', () => {
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true'
        toggle.setAttribute('aria-expanded', String(!isExpanded))
        mobileMenu.classList.toggle('hidden')
        menuIcon.classList.toggle('hidden')
        closeIcon.classList.toggle('hidden')
      })
    }

    // Acordeón móvil
    const accordionToggles = document.querySelectorAll(
      '[data-accordion-toggle]'
    )
    accordionToggles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.closest('.mobile-accordion')
        const content = parent?.querySelector('.accordion-content')
        const chevron = btn.querySelector('.accordion-chevron')

        if (content && chevron) {
          content.classList.toggle('hidden')
          chevron.classList.toggle('rotate-180')
        }
      })
    })
  }

  initHeader()
  document.addEventListener('astro:after-swap', initHeader)
</script>
