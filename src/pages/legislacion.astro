---
import Layout from '@/layouts/Layout.astro'
import { site } from '@/data/institucion'
import PageHero from '@/components/ui/PageHero.astro'
import { legislacion } from '@/data/transparencia'
import ArrowRight from '@/components/icons/ui/ArrowRight.astro'
import FileText from '@/components/icons/ui/FileText.astro'
---

<Layout
  title="Legislación"
  description={`Marco normativo aplicable a la ${site.fullName}`}
>
  <PageHero
    title="Legislación"
    description="Marco normativo interno y general aplicable a la empresa"
  />

  <!-- Contenido -->
  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      {
        legislacion.map((categoria) => (
          <div class="mb-14 last:mb-0">
            <div class="mb-2 flex items-center gap-3">
              <div class="bg-accent h-0.5 w-6 rounded-full" />
              <h2 class="text-primary font-display text-2xl font-normal md:text-3xl">
                {categoria.nombre}
              </h2>
            </div>
            {categoria.descripcion && (
              <p class="text-text-secondary mb-6 ml-9">
                {categoria.descripcion}
              </p>
            )}

            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {categoria.items.map((item) => (
                <a
                  href={item.url}
                  target={item.url !== '#' ? '_blank' : undefined}
                  rel={item.url !== '#' ? 'noopener noreferrer' : undefined}
                  data-track-click={item.url !== '#' ? '' : undefined}
                  data-track-title={item.url !== '#' ? item.titulo : undefined}
                  class="group relative flex items-start gap-3 overflow-hidden rounded-xl border border-gray-200/60 bg-white p-4 transition-all duration-400 hover:-translate-y-0.5 hover:shadow-md"
                >
                  <div class="bg-accent absolute top-0 left-0 h-0.5 w-full origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100" />
                  <div class="text-primary mt-0.5 shrink-0">
                    <FileText class="h-4 w-4" />
                  </div>
                  <span class="group-hover:text-primary text-sm text-text-secondary transition-colors duration-200">
                    {item.titulo}
                  </span>
                  {item.url !== '#' && (
                    <ArrowRight class="group-hover:text-accent mt-0.5 ml-auto h-4 w-4 shrink-0 text-text-muted/30 transition-colors duration-200" />
                  )}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
