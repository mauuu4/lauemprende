---
import Layout from '@/layouts/Layout.astro'
import { site } from '@/data/institucion'
import PageHero from '@/components/ui/PageHero.astro'
import { legislacion } from '@/data/transparencia'
import ArrowRight from '@/components/icons/ui/ArrowRight.astro'
import FileText from '@/components/icons/ui/FileText.astro'
---

<Layout
  title="Legislación"
  description={`Marco normativo aplicable a la ${site.fullName}`}
>
  <PageHero
    title="Legislación"
    description="Marco normativo interno y general aplicable a la empresa"
  />

  <!-- Contenido -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-6">
      {
        legislacion.map((categoria) => (
          <div class="mb-12 last:mb-0">
            <h2 class="text-primary mb-2 text-2xl font-bold md:text-3xl">
              {categoria.nombre}
            </h2>
            {categoria.descripcion && (
              <p class="mb-6 text-gray-600">{categoria.descripcion}</p>
            )}

            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {categoria.items.map((item) => (
                <a
                  href={item.url}
                  target={item.url !== '#' ? '_blank' : undefined}
                  rel={item.url !== '#' ? 'noopener noreferrer' : undefined}
                  class="group flex items-start gap-3 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md"
                >
                  <div class="text-primary mt-0.5 shrink-0">
                    <FileText class="h-5 w-5" />
                  </div>
                  <span class="group-hover:text-primary text-sm font-medium text-gray-700 transition-colors">
                    {item.titulo}
                  </span>
                  {item.url !== '#' && (
                    <ArrowRight class="group-hover:text-primary mt-0.5 ml-auto h-4 w-4 shrink-0 text-gray-400 transition-colors" />
                  )}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
