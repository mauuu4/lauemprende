---
import { Image } from 'astro:assets'
import Layout from '@/layouts/Layout.astro'
import ButtonLink from '@/components/ui/ButtonLink.astro'
import { anuncios } from '@/data/anuncios'

// Ordenar por fecha descendente
const anunciosOrdenados = [...anuncios]
  .filter((a) => a.activo)
  .sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime())
---

<Layout
  title="Anuncios - La UEmprende"
  description="Anuncios institucionales de la Empresa Pública LA UEMPRENDE EP"
>
  <!-- Hero Section -->
  <section
    class="bg-primary relative overflow-hidden py-16 text-white md:py-20"
  >
    <div
      class="absolute inset-0 bg-linear-to-br from-blue-900/20 to-transparent"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-6">
      <div class="text-center">
        <h1 class="mb-4 text-4xl font-bold tracking-tight md:text-5xl">
          Anuncios
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-blue-100">
          Anuncios y comunicaciones institucionales
        </p>
      </div>
    </div>
  </section>

  <!-- Contenido -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-6">
      {
        anunciosOrdenados.length > 0 ? (
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {anunciosOrdenados.map((anuncio) => (
              <article class="group flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                {anuncio.imagen ? (
                  <div class="aspect-video w-full overflow-hidden">
                    <Image
                      src={anuncio.imagen}
                      alt={anuncio.titulo}
                      width={600}
                      height={340}
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="bg-primary/5 flex aspect-video w-full items-center justify-center">
                    <div class="text-primary/30 text-center">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="mx-auto h-12 w-12"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.5"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"
                        />
                      </svg>
                      <p class="mt-2 text-sm font-medium">Anuncio</p>
                    </div>
                  </div>
                )}
                <div class="flex flex-1 flex-col p-6">
                  <time class="mb-2 block text-xs font-medium text-gray-500">
                    {new Date(anuncio.fecha).toLocaleDateString('es-EC', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <h2 class="text-primary mb-2 text-lg font-bold">
                    {anuncio.titulo}
                  </h2>
                  {anuncio.descripcion && (
                    <p class="mb-4 flex-1 text-sm leading-relaxed text-gray-700">
                      {anuncio.descripcion}
                    </p>
                  )}
                  {anuncio.enlaces.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {anuncio.enlaces.map((enlace) => (
                        <ButtonLink
                          variant={enlace.tipo}
                          size="sm"
                          href={enlace.url}
                        >
                          {enlace.texto}
                        </ButtonLink>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="py-20 text-center">
            <h2 class="text-primary mb-2 text-xl font-bold">Próximamente</h2>
            <p class="text-gray-600">
              Pronto publicaremos anuncios institucionales.
            </p>
          </div>
        )
      }
    </div>
  </section>
</Layout>
