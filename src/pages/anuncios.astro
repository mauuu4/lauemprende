---
import Layout from '@/layouts/Layout.astro'
import { site } from '@/data/institucion'
import PageHero from '@/components/ui/PageHero.astro'
import ContentCard from '@/components/ui/ContentCard.astro'
import Megaphone from '@/components/icons/ui/Megaphone.astro'
import { anuncios } from '@/data/contenido'
import { formatDate } from '@/utils/formatDate'

// Ordenar por fecha descendente
const anunciosOrdenados = [...anuncios]
  .filter((a) => a.activo)
  .sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime())
---

<Layout
  title="Anuncios"
  description={`Anuncios institucionales de la ${site.fullName}`}
>
  <PageHero
    title="Anuncios"
    description="Anuncios y comunicaciones institucionales"
  />

  <!-- Contenido -->
  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          anunciosOrdenados.map((anuncio, index) => (
            <ContentCard
              titulo={anuncio.titulo}
              descripcion={anuncio.descripcion}
              fecha={anuncio.fecha}
              fechaFormateada={formatDate(anuncio.fecha)}
              imagen={anuncio.imagen}
              enlaces={anuncio.enlaces}
              loading={index < 1 ? 'eager' : 'lazy'}
            >
              <div slot="placeholder-icon" class="text-primary/20 text-center">
                <Megaphone class="mx-auto h-12 w-12" />
                <p class="mt-2 text-sm font-medium">Anuncio</p>
              </div>
            </ContentCard>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
