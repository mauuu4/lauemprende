---
import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ArrowRight from '@/components/icons/ui/ArrowRight.astro'

const currentYear = new Date().getFullYear()
---

<Layout
  title="Transparencia"
  description="Difusión de la Información Pública - LEY ORGÁNICA DE TRANSPARENCIA Y ACCESO A LA INFORMACIÓN PÚBLICA (LOTAIP)"
>
  <PageHero
    title={`Difusión de la Información Pública Año ${currentYear}`}
    description="Transparencia y acceso a la información pública institucional"
  />

  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <!-- Card principal -->
      <div
        class="relative overflow-hidden rounded-xl border border-gray-200/60 bg-white"
      >
        <!-- Barra dorada superior -->
        <div class="bg-accent h-0.5"></div>

        <div class="p-8 md:p-12">
          <!-- Subtítulo -->
          <h2
            class="text-primary mb-10 text-center font-display text-xl font-normal md:text-2xl"
          >
            LEY ORGÁNICA DE TRANSPARENCIA Y ACCESO A LA INFORMACIÓN PÚBLICA
            (LOTAIP)
          </h2>

          <!-- Grid de artículos -->
          <div class="mb-10 grid gap-8 md:grid-cols-2">
            <!-- Artículo 7 -->
            <div>
              <h3 class="text-primary mb-3 text-sm font-bold">
                Art. 7.- Derecho de acceso a la Información Pública.
              </h3>
              <p class="text-sm leading-relaxed text-text-secondary">
                El derecho de acceso a la información pública comprende el
                derecho a buscar, acceder, solicitar, investigar, difundir,
                recibir, copiar, analizar, reprocesar, reutilizar y redistribuir
                información. Toda la información producida, obtenida, adquirida,
                transformada o en posesión de los sujetos obligados es pública y
                accesible a cualquier persona en los términos y condiciones
                establecidos en la presente Ley, la normativa vigente y en los
                instrumentos internacionales aprobados y ratificados por el
                Estado ecuatoriano.
              </p>
            </div>

            <!-- Artículo 19 -->
            <div>
              <h3 class="text-primary mb-3 text-sm font-bold">
                Artículo 19.- Transparencia activa.
              </h3>
              <p class="text-sm leading-relaxed text-text-secondary">
                Los sujetos obligados establecidos en los literales a), b), d),
                f), g) y h) del artículo 8 de la presente Ley, difundirán a
                través de un portal informático web de información o a través de
                los medios que dispongan, y que sean de fácil acceso y
                comprensión, la siguiente información mínima actualizada
                mensualmente, que, para efectos de esta Ley, se la considera de
                naturaleza obligatoria.
              </p>
            </div>
          </div>

          <!-- Descripción del portal -->
          <div class="mb-8 rounded-xl border border-gray-200/60 bg-surface p-6">
            <p class="text-sm leading-relaxed text-text-secondary">
              El Portal Nacional de Transparencia (PNT) 2.0 surge como una
              herramienta mejorada para fortalecer el derecho humano de acceso a
              la información pública, conforme a lo establecido en la Ley
              Orgánica de Transparencia y Acceso a la Información Pública
              (LOTAIP), modernizando su cumplimiento y garantizando datos de
              calidad, libres y reutilizables. A través de este portal puedes
              consultar los archivos que la Empresa Pública LA UEMPRENDE EP
              publica mensualmente.
            </p>
          </div>

          <!-- Botón -->
          <div class="text-center">
            <a
              href="https://transparencia.dpe.gob.ec/entidades/1872"
              target="_blank"
              rel="noopener noreferrer"
              class="bg-accent text-primary hover:bg-accent-light inline-flex items-center gap-2 rounded-lg px-8 py-3 font-semibold shadow-md transition-all duration-300 hover:shadow-lg"
            >
              Ingresar al Portal
              <ArrowRight class="h-4 w-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
