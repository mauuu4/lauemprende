---
import Layout from '@/layouts/Layout.astro'
import { directorio } from '@/data/directorio'
import { correosInstitucionales } from '@/data/correosInstitucionales'
import { infoContacto } from '@/data/contacto'
import PersonCard from '@/components/ui/PersonCard.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import ContactInfoItem from '@/components/ui/ContactInfoItem.astro'
import Mail from '@/components/icons/contact/Mail.astro'
import MapPin from '@/components/icons/contact/MapPin.astro'
import Phone from '@/components/icons/contact/Phone.astro'
---

<Layout
  title="Contactos - La UEmprende"
  description="Directorio de contactos y estructura organizacional de La UEmprende"
>
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeader title="Directorio de Contactos" />

      {
        directorio.map(({ departamento, personal }) => (
          <div class="mb-12">
            <h2 class="text-primary mb-6 text-xl font-bold uppercase">
              {departamento}
            </h2>
            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {personal.map((persona) => (
                <PersonCard {...persona} />
              ))}
            </div>
          </div>
        ))
      }

      <!-- Correos Institucionales por Área -->
      <div class="mt-12 mb-12">
        <h2 class="text-primary mb-6 text-xl font-bold uppercase">
          Correos Institucionales por Área
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {
            correosInstitucionales.map((contacto) => (
              <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg">
                <h3 class="text-primary mb-3 text-lg font-bold">
                  {contacto.area}
                </h3>
                <p class="mb-4 text-sm leading-relaxed text-gray-700">
                  {contacto.descripcion}
                </p>
                <a
                  href={`mailto:${contacto.email}`}
                  class="text-primary hover:text-primary-light inline-flex items-center gap-2 text-sm font-semibold transition-colors"
                >
                  <Mail />
                  {contacto.email}
                </a>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Información de contacto general -->
      <div class="mt-8 rounded-xl bg-white p-8 shadow-md">
        <h2 class="text-primary mb-8 text-center text-2xl font-bold">
          Información de Contacto General
        </h2>
        <div class="grid gap-8 md:grid-cols-3">
          <ContactInfoItem label="Dirección" value={infoContacto.direccion}>
            <MapPin />
          </ContactInfoItem>
          <ContactInfoItem
            label="Teléfono"
            value={`${infoContacto.telefono} ${infoContacto.telefonoExtension}`}
          >
            <Phone />
          </ContactInfoItem>
          <ContactInfoItem label="Email" value={infoContacto.emailPrincipal}>
            <Mail />
          </ContactInfoItem>
        </div>
      </div>
    </div>
  </section>
</Layout>
