---
import Layout from '@/layouts/Layout.astro'
import ButtonLink from '@/components/ui/ButtonLink.astro'
---

<Layout
  title="Página no encontrada"
  description="La página que buscas no existe o fue movida."
>
  <section
    class="bg-surface relative flex min-h-[70vh] flex-col items-center justify-center overflow-hidden px-6 py-24 text-center"
  >
    <!-- Patrón decorativo -->
    <div
      class="bg-grid-pattern absolute inset-0 opacity-50"
      aria-hidden="true"
    >
    </div>

    <div class="relative">
      <p
        class="text-accent mb-4 font-display text-8xl font-normal sm:text-[10rem]"
      >
        404
      </p>
      <h1 class="text-primary mb-4 font-display text-2xl font-normal sm:text-3xl">
        Página no encontrada
      </h1>
      <p class="text-text-muted mb-10 max-w-md text-base leading-relaxed">
        Lo sentimos, la página que buscas no existe o fue movida a otra
        dirección.
      </p>
      <ButtonLink href="/" variant="primary" size="lg" target="_self">
        Volver al inicio
      </ButtonLink>
    </div>
  </section>
</Layout>
