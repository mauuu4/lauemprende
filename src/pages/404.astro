---
import Layout from '@/layouts/Layout.astro'
import ButtonLink from '@/components/ui/ButtonLink.astro'
---

<Layout
  title="Página no encontrada"
  description="La página que buscas no existe o fue movida."
>
  <section
    class="flex min-h-[60vh] flex-col items-center justify-center px-6 py-20 text-center"
  >
    <p class="text-accent mb-2 text-7xl font-bold sm:text-9xl">404</p>
    <h1 class="text-primary mb-4 text-2xl font-bold sm:text-3xl">
      Página no encontrada
    </h1>
    <p class="text-muted mb-8 max-w-md text-lg">
      Lo sentimos, la página que buscas no existe o fue movida a otra dirección.
    </p>
    <ButtonLink href="/" variant="primary" size="lg" target="_self">
      Volver al inicio
    </ButtonLink>
  </section>
</Layout>
