---
import Layout from '@/layouts/Layout.astro'
import { site } from '@/data/institucion'
import PageHero from '@/components/ui/PageHero.astro'
import ContentCard from '@/components/ui/ContentCard.astro'
import Newspaper from '@/components/icons/ui/Newspaper.astro'
import { noticias } from '@/data/contenido'
import { formatDate } from '@/utils/formatDate'
---

<Layout
  title="Noticias"
  description={`Noticias y novedades de la ${site.fullName}`}
>
  <PageHero
    title="Noticias"
    description="Mantente informado sobre las novedades institucionales"
  />

  <!-- Contenido -->
  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          noticias.map((noticia) => (
            <ContentCard
              titulo={noticia.titulo}
              descripcion={noticia.descripcion}
              fecha={noticia.fecha}
              fechaFormateada={formatDate(noticia.fecha)}
              imagen={noticia.imagen}
              video={noticia.video}
            >
              <Newspaper
                slot="placeholder-icon"
                class="text-primary/30 mx-auto h-12 w-12"
              />
            </ContentCard>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
