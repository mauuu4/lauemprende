---
import Layout from '@/layouts/Layout.astro'
import { cursos, invitaciones } from '@/data/carousels'
import { anuncioDestacado } from '@/data/contenido'
import AnnouncementModal from '@/components/ui/AnnouncementModal.astro'
import Carousel from '@/components/ui/Carousel.astro'
import Hero from '@/components/sections/Hero.astro'
import Counter from '@/components/ui/Counter.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import Calendar from '@/components/icons/ui/Calendar.astro'
import TrendUp from '@/components/icons/ui/TrendUp.astro'

// Ordenar para que los más recientes (ID más alto) aparezcan primero
const cursosOrdenados = [...cursos].reverse()
const invitacionesOrdenadas = [...invitaciones].reverse()
---

<Layout title="Inicio">
  {
    anuncioDestacado?.imagen && (
      <AnnouncementModal
        titulo={anuncioDestacado.titulo}
        descripcion={anuncioDestacado.descripcion}
        imagen={anuncioDestacado.imagen}
      />
    )
  }
  <Hero />

  <section id="cursos" class="scroll-mt-16 bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeader title="Cursos" />
      <Carousel items={cursosOrdenados} id="cursos" loading="eager" />
    </div>
  </section>

  <section id="invitaciones" class="scroll-mt-16 bg-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeader title="Invitaciones a procesos de contratación" />
      <Carousel items={invitacionesOrdenadas} id="invitaciones" />
    </div>
  </section>

  <section id="estadisticas" class="scroll-mt-16 bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeader title="Estadísticas de Visitas" />
      <div
        class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mx-auto lg:max-w-3xl"
      >
        <Counter
          id="counter-last"
          end={0}
          label="Visitas mes pasado"
          icon={Calendar}
          data-dynamic
        />
        <Counter
          id="counter-current"
          end={0}
          label="Visitas este mes"
          icon={TrendUp}
          data-dynamic
        />
      </div>
    </div>
  </section>
</Layout>
