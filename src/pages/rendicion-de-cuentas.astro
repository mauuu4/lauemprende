---
import Layout from '@/layouts/Layout.astro'
import { site } from '@/data/institucion'
import PageHero from '@/components/ui/PageHero.astro'
import EnlaceGroup from '@/components/ui/EnlaceGroup.astro'
import ChevronDown from '@/components/icons/ui/ChevronDown.astro'
import { rendicionCuentas } from '@/data/transparencia'
---

<Layout
  title="Rendición de Cuentas"
  description={`Informes de Rendición de Cuentas de la ${site.fullName}`}
>
  <PageHero
    title="Rendición de Cuentas"
    description="Transparencia y responsabilidad en la gestión institucional"
  />

  <!-- Contenido -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-4xl px-6">
      {
        rendicionCuentas.map((anio, index) => (
          <details
            class="group mb-6 overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm"
            open={index === 0}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between px-6 py-5 transition-colors hover:bg-gray-50">
              <h2 class="text-primary text-xl font-bold md:text-2xl">
                {anio.anio}
              </h2>
              <ChevronDown
                size={24}
                class="text-primary shrink-0 transition-transform duration-300 group-open:rotate-180"
              />
            </summary>

            <div class="border-t border-gray-100 px-6 py-6">
              <div class="space-y-6">
                {anio.informes.map((informe) => (
                  <div class="flex flex-col gap-6 sm:flex-row">
                    <div class="flex flex-1 flex-col justify-center">
                      <h3 class="mb-2 text-lg font-bold text-gray-900">
                        {informe.titulo}
                      </h3>
                      {informe.descripcion && (
                        <p class="mb-4 text-sm text-gray-600">
                          {informe.descripcion}
                        </p>
                      )}
                      <EnlaceGroup enlaces={informe.enlaces} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </section>
</Layout>
