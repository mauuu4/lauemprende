---
import { Image } from 'astro:assets'
import Layout from '@/layouts/Layout.astro'
import { site } from '@/data/institucion'
import PageHero from '@/components/ui/PageHero.astro'
import EnlaceGroup from '@/components/ui/EnlaceGroup.astro'
import ChevronDown from '@/components/icons/ui/ChevronDown.astro'
import { rendicionCuentas } from '@/data/transparencia'
---

<Layout
  title="Rendición de Cuentas"
  description={`Informes de Rendición de Cuentas de la ${site.fullName}`}
>
  <PageHero
    title="Rendición de Cuentas"
    description="Transparencia y responsabilidad en la gestión institucional"
  />

  <!-- Contenido -->
  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6">
      {
        rendicionCuentas.map((anio, index) => (
          <details
            class="group mb-5 overflow-hidden rounded-xl border border-gray-200/60 bg-white"
            open={index === 0}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between px-6 py-5 transition-colors duration-200 hover:bg-surface">
              <h2 class="text-primary font-display text-xl font-normal md:text-2xl">
                {anio.anio}
              </h2>
              <ChevronDown
                size={20}
                class="text-text-muted shrink-0 transition-transform duration-300 group-open:rotate-180"
              />
            </summary>

            <div class="border-t border-gray-100 px-6 py-6">
              <div class="space-y-6">
                {anio.informes.map((informe) => (
                  <div class="flex flex-col gap-6 sm:flex-row">
                    {informe.imagen && (
                      <div class="shrink-0 sm:w-56">
                        <Image
                          src={informe.imagen}
                          alt={informe.titulo}
                          width={600}
                          height={850}
                          format="webp"
                          class="w-full rounded-lg object-cover shadow-md"
                        />
                      </div>
                    )}
                    <div class="flex flex-1 flex-col justify-center">
                      <h3
                        class="text-primary mb-2 font-display text-lg font-normal"
                        aria-label={informe.titulo}
                      >
                        {informe.titulo}
                      </h3>
                      {informe.descripcion && (
                        <p class="text-text-secondary mb-4 text-sm">
                          {informe.descripcion}
                        </p>
                      )}
                      <EnlaceGroup enlaces={informe.enlaces} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </section>
</Layout>

