---
import '@/styles/global.css'
import Header from '@/components/common/Header.astro'
import Footer from '@/components/common/Footer.astro'
import { site, infoContacto } from '@/data/institucion'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title: rawTitle,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props

// Si se pasa un titulo, se construye "Titulo - La UEmprende"; si no, solo el nombre del sitio
const title = rawTitle ? `${rawTitle} - ${site.name}` : site.name

const currentPath = Astro.url.pathname
const canonicalUrl = `${site.url}${currentPath}`
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${site.url}${ogImage}`

// JSON-LD structured data para la organizacion
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'GovernmentOrganization',
  name: site.fullName,
  alternateName: site.name,
  url: site.url,
  logo: `${site.url}/favicon.svg`,
  description: site.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Velasco 2-39 entre Salinas y Juan Montalvo',
    addressLocality: 'Ibarra',
    addressCountry: 'EC',
  },
  telephone: infoContacto.telefono,
  email: infoContacto.emailPrincipal,
  sameAs: [
    infoContacto.redesSociales.facebook,
    infoContacto.redesSociales.youtube,
    infoContacto.redesSociales.twitter,
  ],
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Preconnect a Google Fonts para carga mas rapida -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={site.fullName} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
  </head>

  <body>
    <Header />

    <main class="pt-12">
      <slot />
    </main>

    <Footer />

    <script>
      import '@/scripts/trackClicks'
    </script>
  </body>
</html>
