---
import '@/styles/global.css'
import Header from '@/components/common/Header.astro'
import Footer from '@/components/common/Footer.astro'
import { site } from '@/data/institucion'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title: rawTitle,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props

// Si se pasa un título, se construye "Título - La UEmprende"; si no, solo el nombre del sitio
const title = rawTitle ? `${rawTitle} - ${site.name}` : site.name

const currentPath = Astro.url.pathname
const canonicalUrl = `${site.url}${currentPath}`
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${site.url}${ogImage}`} />
    <meta property="og:site_name" content={site.fullName} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site.url}${ogImage}`} />

    <title>{title}</title>
  </head>

  <body>
    <Header />

    <main class="pt-12">
      <slot />
    </main>

    <Footer />
  </body>
</html>
